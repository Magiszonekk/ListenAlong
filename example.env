# DRIFT_FACTOR_PCT=15
# DRIFT_BASE_MS=1000

# Prefetch & URL cache (optional — defaults used if not set)
# PREFETCH_AHEAD=5
# WARM_CACHE_ENABLED=0
# WARM_CACHE_TOP_N=50
# WARM_CACHE_MIN_TTL_M=15
