PORT=3000
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
REDIRECT_URI=https://yourdomain/callback
GOOGLE_EMAIL=
GOOGLE_PASSWORD=

# Search scoring weights (optional — defaults used if not set)
# YT_SEARCH_COUNT=5
# ODESLI_BONUS_MS=0
# TITLE_BONUS_MS=15000
# SCRIPT_BONUS_MS=10000

